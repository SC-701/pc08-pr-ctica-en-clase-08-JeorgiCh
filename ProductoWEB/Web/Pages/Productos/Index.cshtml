@page
@model Web.Pages.Productos.IndexModel
@{
    ViewData["Title"] = "Catálogo de Productos";
}

<div class="container mt-5 pt-5">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h1 class="display-4 fw-bold text-primary">Productos</h1>
        </div>
        <div class="col-auto">
            <a class="btn btn-success btn-lg rounded-pill shadow-sm" asp-page="./Agregar">
                <i class="bi bi-plus-circle-fill me-2"></i>Nuevo Producto
            </a>
        </div>
    </div>

    <hr class="my-4" />

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @if (Model.productos != null && Model.productos.Any())
        {
            @foreach (var item in Model.productos)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 hover-shadow transition">
                        <div class="card-header bg-primary bg-gradient text-white py-3">
                            <h5 class="card-title mb-0">@item.Nombre</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text text-secondary">@item.Descripcion</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="h4 mb-0 text-dark">@item.Precio.ToString("C")</span>
                                <span class="badge bg-light text-dark border">ID: @item.Id.ToString().Substring(0, 5)...</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 pb-3">
                            <div class="btn-group w-100" role="group">
                                <a class="btn btn-outline-primary" asp-page="./Detalles" asp-route-id="@item.Id">
                                    Detalles
                                </a>
                                <a class="btn btn-outline-primary" asp-page="./Editar" asp-route-id="@item.Id">
                                    <i class="bi bi-pencil-square me-1"></i>Editar
                                </a>
                                <a class="btn btn-outline-danger" asp-page="./Eliminar" asp-route-id="@item.Id">
                                    <i class="bi bi-trash-fill me-1"></i>Eliminar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-box-seam display-1 text-muted"></i>
                <p class="mt-3 fs-4 text-muted">No hay productos disponibles.</p>
            </div>
        }
    </div>
</div>