@page "{id:guid}"
@model Web.Pages.Productos.EditarModel
@{
    ViewData["Title"] = "Editar Producto";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="./Index" class="text-decoration-none">Productos</a></li>
                    <li class="breadcrumb-item active">Editar</li>
                </ol>
            </nav>

            <div class="card shadow-lg border-0 overflow-hidden">
                <div class="card-header bg-warning py-3">
                    <h3 class="mb-0 text-white fw-bold text-center">
                        <i class="bi bi-pencil-square me-2"></i>Editar Producto
                    </h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm" role="alert"></div>

                        <input type="hidden" asp-for="producto.Id" />

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="producto.Nombre" class="form-label fw-bold text-dark">Nombre del Producto</label>
                                <input asp-for="producto.Nombre" class="form-control form-control-lg border-2" placeholder="Ingrese el nombre" />
                                <span asp-validation-for="producto.Nombre" class="text-danger small fw-bold"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="producto.Descripcion" class="form-label fw-bold text-dark">Descripción Detallada</label>
                                <textarea asp-for="producto.Descripcion" class="form-control border-2" rows="3" placeholder="Breve descripción del producto..."></textarea>
                                <span asp-validation-for="producto.Descripcion" class="text-danger small fw-bold"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="producto.CodigoBarras" class="form-label fw-bold text-dark">Código de Barras</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-upc-scan"></i></span>
                                    <input asp-for="producto.CodigoBarras" class="form-control border-2" />
                                </div>
                                <span asp-validation-for="producto.CodigoBarras" class="text-danger small fw-bold"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="IdSubCategoria" class="form-label fw-bold">ID Subcategoría</label>
                                <input asp-for="IdSubCategoria" class="form-control" />
                                <span asp-validation-for="IdSubCategoria" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="producto.Precio" class="form-label fw-bold text-dark">Precio de Venta</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light fw-bold">₡</span>
                                    <input asp-for="producto.Precio" class="form-control form-control-lg border-2" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="producto.Precio" class="text-danger small fw-bold"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="producto.Stock" class="form-label fw-bold text-dark">Existencias (Stock)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-box-seam"></i></span>
                                    <input asp-for="producto.Stock" class="form-control form-control-lg border-2" type="number" />
                                </div>
                                <span asp-validation-for="producto.Stock" class="text-danger small fw-bold"></span>
                            </div>
                        </div>

                        <div class="mt-5 d-grid gap-3">
                            <button type="submit" class="btn btn-warning btn-lg rounded-pill shadow-sm text-white fw-bold">
                                <i class="bi bi-arrow-repeat me-2"></i>Actualizar Cambios
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary btn-lg rounded-pill fw-bold">
                                Cancelar y volver
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}