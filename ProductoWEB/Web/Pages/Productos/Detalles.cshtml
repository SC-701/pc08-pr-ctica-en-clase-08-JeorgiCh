@page "{id:guid}"
@model Web.Pages.Productos.DetallesModel
@{
    ViewData["Title"] = "Detalles del Producto";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="./Index" class="text-decoration-none">Productos</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Detalles</li>
                </ol>
            </nav>

            <div class="card shadow-lg border-0 overflow-hidden">
                <div class="card-header bg-primary text-white py-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h2 class="mb-0 fw-bold">Información del Producto</h2>
                        <i class="bi bi-info-circle-fill fs-3"></i>
                    </div>
                </div>
                <div class="card-body p-5">
                    <div class="row">
                        <div class="col-md-4 text-center mb-4 mb-md-0">
                            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 150px; height: 150px;">
                                <i class="bi bi-box-seam text-primary" style="font-size: 5rem;"></i>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <h3 class="text-dark fw-bold mb-3">@Model.producto.Nombre</h3>

                            <div class="mb-4">
                                <label class="text-uppercase small fw-bold text-muted d-block">Descripción</label>
                                <p class="fs-5 text-secondary">@Model.producto.Descripcion</p>
                            </div>

                            <div class="mb-4">
                                <label class="text-uppercase small fw-bold text-muted d-block">SubCategoria</label>
                                <p class="fs-5 text-secondary">@Model.producto.SubCategoria</p>
                            </div>

                            <div class="row g-3">
                                <div class="col-6">
                                    <label class="text-uppercase small fw-bold text-muted d-block">Precio Unitario</label>
                                    <span class="fs-4 fw-bold text-success">@Model.producto.Precio.ToString("C")</span>
                                </div>
                                <div class="col-6">
                                    <label class="text-uppercase small fw-bold text-muted d-block">Identificador (ID)</label>
                                    <span class="badge bg-light text-dark border p-2">@Model.producto.Id</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light p-4 text-end">
                    <a class="btn btn-outline-secondary btn-lg rounded-pill px-4 me-2" asp-page="./Index">
                        <i class="bi bi-arrow-left me-2"></i>Regresar
                    </a>
                    <a class="btn btn-warning text-white btn-lg rounded-pill px-4" asp-page="./Edit" asp-route-id="@Model.producto.Id">
                        <i class="bi bi-pencil-square me-2"></i>Editar Producto
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>